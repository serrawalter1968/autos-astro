---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Solicitudes de Prueba">
  <section class="solicitudes-hero">
    <div class="solicitudes-hero-content">
      <h1>Solicitudes de Prueba de Manejo</h1>
      <p>Administra las solicitudes recibidas</p>
    </div>
  </section>

  <section class="solicitudes-section">
    <div class="container">
      <div class="solicitudes-actions">
        <button class="btn btn-outline" onclick="loadSolicitudes()">Actualizar Lista</button>
        <button class="btn btn-primary" onclick="clearSolicitudes()">Limpiar Todo</button>
      </div>
      
      <div id="solicitudes-container">
        <p class="loading">Cargando solicitudes...</p>
      </div>
      
      <div class="empty-state" id="empty-state" style="display: none;">
        <div class="empty-icon">📋</div>
        <h3>No hay solicitudes</h3>
        <p>Las solicitudes de prueba de manejo aparecerán aquí</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .solicitudes-hero {
    height: 30vh;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--bg-card) 0%, var(--bg-dark) 100%);
    border-bottom: 1px solid rgba(201, 169, 98, 0.1);
  }

  .solicitudes-hero-content {
    text-align: center;
    padding: 0 2rem;
  }

  .solicitudes-hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .solicitudes-hero p {
    color: var(--text-muted);
  }

  .solicitudes-section {
    padding: 4rem 0;
  }

  .solicitudes-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    justify-content: center;
  }

  .loading {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem;
  }

  .solicitud-card {
    background: var(--bg-card);
    border-radius: 4px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.03);
    transition: all 0.3s;
  }

  .solicitud-card:hover {
    border-color: rgba(201, 169, 98, 0.3);
  }

  .solicitud-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .solicitud-vehiculo {
    font-size: 1.2rem;
    font-family: 'Playfair Display', serif;
    color: var(--accent);
  }

  .solicitud-fecha {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .solicitud-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .solicitud-field {
    display: flex;
    flex-direction: column;
  }

  .solicitud-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.3rem;
  }

  .solicitud-value {
    color: var(--text-light);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-muted);
  }

  .empty-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
    opacity: 0.5;
  }

  .empty-state h3 {
    font-size: 1.5rem;
    color: var(--text-light);
    margin-bottom: 0.5rem;
  }

  .total-solicitudes {
    text-align: center;
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }
</style>

<script>
  function loadSolicitudes() {
    const container = document.getElementById('solicitudes-container');
    const emptyState = document.getElementById('empty-state');
    
    const solicitudes = JSON.parse(localStorage.getItem('solicitudesPrueba') || '[]');
    
    if (solicitudes.length === 0) {
      container.innerHTML = '';
      emptyState.style.display = 'block';
      return;
    }
    
    emptyState.style.display = 'none';
    
    container.innerHTML = `
      <p class="total-solicitudes">Total de solicitudes: ${solicitudes.length}</p>
      ${solicitudes.map(s => `
        <div class="solicitud-card">
          <div class="solicitud-header">
            <span class="solicitud-vehiculo">${s.vehiculo || 'Vehículo no especificado'}</span>
            <span class="solicitud-fecha">${formatDate(s.fechaSolicitud)}</span>
          </div>
          <div class="solicitud-grid">
            <div class="solicitud-field">
              <span class="solicitud-label">Nombre</span>
              <span class="solicitud-value">${s.nombre || '-'}</span>
            </div>
            <div class="solicitud-field">
              <span class="solicitud-label">Teléfono</span>
              <span class="solicitud-value">${s.telefono || '-'}</span>
            </div>
            <div class="solicitud-field">
              <span class="solicitud-label">Email</span>
              <span class="solicitud-value">${s.email || '-'}</span>
            </div>
            <div class="solicitud-field">
              <span class="solicitud-label">Fecha Preferida</span>
              <span class="solicitud-value">${s.fecha || '-'}</span>
            </div>
            <div class="solicitud-field">
              <span class="solicitud-label">Horario</span>
              <span class="solicitud-value">${s.horario === 'mañana' ? 'Mañana (9:00 - 12:00)' : s.horario === 'tarde' ? 'Tarde (14:00 - 18:00)' : '-'}</span>
            </div>
            <div class="solicitud-field">
              <span class="solicitud-label">Comentarios</span>
              <span class="solicitud-value">${s.mensaje || 'Sin comentarios'}</span>
            </div>
          </div>
        </div>
      `).reverse().join('')}
    `;
  }

  function formatDate(isoString) {
    const date = new Date(isoString);
    return date.toLocaleDateString('es-ES', {
      day: '2-digit',
      month: '2-digit',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  }

  function clearSolicitudes() {
    if (confirm('¿Estás seguro de que quieres eliminar todas las solicitudes?')) {
      localStorage.removeItem('solicitudesPrueba');
      loadSolicitudes();
    }
  }

  document.addEventListener('DOMContentLoaded', loadSolicitudes);
</script>